# Linor Admin Panel — environment example
# Copy this file to `.env.local` and adjust as needed.

# API mode: "mock" uses the in-memory typed mock layer; "live" hits VITE_API_BASE_URL.
VITE_API_MODE=mock

# Used only when VITE_API_MODE=live
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Telemetry toggle (no-op in dev)
VITE_TELEMETRY_ENABLED=false
